<% content_for :title do %>
  <%= I18n.t('panel.residence_certificates.index.title') %>
<% end %>

<% content_for :breadcrumb do %>
  <li><%= link_to I18n.t('panel.residence_certificates.index.title'), panel_residence_certificates_path %></li>
  <li><%= @residence_certificate.id %></li>
<% end %>

<div class="w-full">
  <h1 class="font-bold text-4xl my-4"><%= I18n.t('panel.residence_certificates.index.title') %></h1>
  <h3 class="font-bold text-xl mb-4"><%= I18n.t('panel.residence_certificates.show.identifier', id: @residence_certificate.id) %></h3>

  <div class="flex flex-row gap-2 mb-4">
    <%= link_to raw(icon('list') + I18n.t('actions.index')), panel_residence_certificates_path, class: "btn btn-soft" %>
  </div>

  <dl class="mb-4 divide-y divide-gray-400 w-1/3">
    <div class="p-2 grid gap-2">
      <dt class="font-medium"><%= I18n.t('activerecord.attributes.residence_certificate.folio') %></dt>
      <dd><%= @residence_certificate.folio || "—" %></dd>
    </div>
    <div class="p-2 grid gap-2">
      <dt class="font-medium"><%= I18n.t('activerecord.attributes.residence_certificate.member') %></dt>
      <dd><%= @residence_certificate.member.name %></dd>
    </div>
    <div class="p-2 grid gap-2">
      <dt class="font-medium"><%= I18n.t('activerecord.attributes.residence_certificate.status') %></dt>
      <dd><%= I18n.t("activerecord.attributes.residence_certificate/status.#{@residence_certificate.status}") %></dd>
    </div>
    <div class="p-2 grid gap-2">
      <dt class="font-medium"><%= I18n.t('activerecord.attributes.residence_certificate.purpose') %></dt>
      <dd><%= @residence_certificate.purpose %></dd>
    </div>
    <div class="p-2 grid gap-2">
      <dt class="font-medium"><%= I18n.t('activerecord.attributes.residence_certificate.issue_date') %></dt>
      <dd><%= @residence_certificate.issue_date || "—" %></dd>
    </div>
    <div class="p-2 grid gap-2">
      <dt class="font-medium"><%= I18n.t('activerecord.attributes.residence_certificate.expiration_date') %></dt>
      <dd><%= @residence_certificate.expiration_date || "—" %></dd>
    </div>
    <div class="p-2 grid gap-2">
      <dt class="font-medium"><%= I18n.t('activerecord.attributes.residence_certificate.notes') %></dt>
      <dd><%= @residence_certificate.notes || "—" %></dd>
    </div>
    <div class="p-2 grid gap-2">
      <dt class="font-medium"><%= I18n.t('activerecord.attributes.residence_certificate.created_at') %></dt>
      <dd><%= l(@residence_certificate.created_at.to_date) %></dd>
    </div>
    <% if @residence_certificate.amount.present? %>
      <div class="p-2 grid gap-2">
        <dt class="font-medium"><%= I18n.t('activerecord.attributes.residence_certificate.amount') %></dt>
        <dd>$<%= number_with_delimiter(@residence_certificate.amount) %> CLP</dd>
      </div>
    <% end %>
  </dl>

  <% if @residence_certificate.pending_payment? && @residence_certificate.amount.present? %>
    <div class="my-6">
      <%= link_to I18n.t('panel.payments.actions.pay_with_mercadopago'), new_panel_payment_path(certificate_id: @residence_certificate.id), class: "btn btn-primary btn-lg" %>
      <p class="text-sm text-base-content/70 mt-2"><%= I18n.t('panel.payments.show.help') %></p>
    </div>
  <% end %>

  <% if @residence_certificate.paid? && !@residence_certificate.issued? %>
    <div class="alert alert-info my-6">
      <%= I18n.t('panel.residence_certificates.show.processing') %>
    </div>
  <% end %>

  <% if @residence_certificate.issued? && @residence_certificate.pdf_document.attached? %>
    <div class="my-6">
      <%= link_to I18n.t('panel.residence_certificates.show.download_pdf'), rails_blob_path(@residence_certificate.pdf_document, disposition: "attachment"), class: "btn btn-success btn-lg" %>
      <p class="text-sm text-base-content/70 mt-2">
        <%= I18n.t('panel.residence_certificates.show.validation_code') %>:
        <span class="font-mono font-bold"><%= @residence_certificate.validation_code %></span>
      </p>
    </div>
  <% end %>
</div>
