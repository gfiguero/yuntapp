<% content_for :title do %>
  <%= I18n.t('panel.members.index.title') %>
<% end %>

<% content_for :breadcrumb do %>
  <li><%= I18n.t('panel.members.index.title') %></li>
<% end %>

<div class="w-full">
  <h1 class="font-bold text-4xl my-4"><%= I18n.t('panel.members.index.title') %></h1>

  <div class="flex flex-row gap-2 mb-4">
    <%= link_to raw(icon('new') + I18n.t('actions.new')), new_panel_member_path, class: "btn btn-soft btn-primary" %>
  </div>

  <div class="overflow-x-auto rounded-box border border-base-content/5 bg-base-100">
    <table class="table">
      <thead>
        <tr>
          <th><%= I18n.t('activerecord.attributes.member.name') %></th>
          <th><%= I18n.t('activerecord.attributes.member.run') %></th>
          <th><%= I18n.t('activerecord.attributes.member.status') %></th>
          <th class="w-20"><%= I18n.t('shared.table.actions') %></th>
        </tr>
      </thead>
      <tbody>
      <% @residencies.each do |residency| %>
        <tr class="hover:bg-base-300">
          <td><%= residency.name %></td>
          <td><%= residency.run %></td>
          <td>
            <% if residency.pending? %>
              <span class="badge badge-warning badge-sm"><%= I18n.t('activerecord.attributes.member/status.pending') %></span>
            <% elsif residency.approved? %>
              <span class="badge badge-success badge-sm"><%= I18n.t('activerecord.attributes.member/status.approved') %></span>
            <% elsif residency.rejected? %>
              <span class="badge badge-error badge-sm"><%= I18n.t('activerecord.attributes.member/status.rejected') %></span>
            <% end %>
          </td>
          <td>
            <%= icon_link_to 'show', panel_member_path(residency), I18n.t('actions.show'), class: "btn btn-sm btn-soft btn-info" %>
          </td>
        </tr>
      <% end %>
      </tbody>
    </table>
  </div>
</div>
