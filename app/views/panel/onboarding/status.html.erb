<div class="w-full">
  <h1 class="font-bold text-4xl my-4"><%= I18n.t('panel.onboarding.status.title') %></h1>
  <p class="text-base-content/60 mb-6"><%= I18n.t('panel.onboarding.status.description') %></p>

  <div class="grid grid-cols-1 gap-4">
    <%= render "shared/onboarding/onboarding_data_card", onboarding_request: @onboarding_request %>
    <%= render "shared/onboarding/association_card", onboarding_request: @onboarding_request %>

    <% if @identity_request %>
      <%= render "shared/onboarding/identity_card", identity_request: @identity_request %>
    <% end %>

    <% if @residence_request %>
      <%= render "shared/onboarding/residence_card", residence_request: @residence_request %>
    <% end %>
  </div>

  <% if @onboarding_request&.pending? %>
    <div class="mt-6">
      <%= button_to I18n.t('panel.onboarding.status.cancel_button'),
            panel_onboarding_cancel_path,
            method: :delete,
            class: "btn btn-soft btn-warning",
            data: { turbo_confirm: I18n.t('panel.onboarding.status.cancel_confirm') } %>
      <p class="text-xs text-base-content/60 mt-2"><%= I18n.t('panel.onboarding.status.cancel_help') %></p>
    </div>
  <% end %>
</div>
