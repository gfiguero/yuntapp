<% content_for :title do %>
  Mi Cuenta
<% end %>

<% content_for :breadcrumb do %>
  <li>Mi Cuenta</li>
<% end %>

<div class="w-full">
  <h1 class="font-bold text-4xl my-4">Mi Cuenta</h1>
  <p class="mb-4 text-base-content/70">Administra tus credenciales de acceso: correo, contraseña y eliminación de la cuenta.</p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    <div class="card bg-base-100 shadow-xl">
      <div class="card-body">
        <h2 class="card-title mb-4">Credenciales de Acceso</h2>

        <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "grid gap-4" }) do |f| %>
          <%= render "users/shared/error_messages", resource: resource %>

          <%= f.label :email, "Email", class: "floating-label" do %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input w-full", placeholder: "Email" %>
            <span>Email</span>
          <% end %>

          <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
            <div class="alert alert-warning">
              <span>Esperando confirmación para: <%= resource.unconfirmed_email %></span>
            </div>
          <% end %>

          <div>
            <%= f.label :password, "Nueva contraseña", class: "floating-label" do %>
              <%= f.password_field :password, autocomplete: "new-password", class: "input w-full", placeholder: "Nueva contraseña" %>
              <span>Nueva contraseña</span>
            <% end %>
            <p class="text-xs text-base-content/50 mt-1">Dejar en blanco si no deseas cambiarla<%= " (#{@minimum_password_length} caracteres mínimo)" if @minimum_password_length %></p>
          </div>

          <%= f.label :password_confirmation, "Confirmar contraseña", class: "floating-label" do %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "input w-full", placeholder: "Confirmar contraseña" %>
            <span>Confirmar contraseña</span>
          <% end %>

          <div class="divider"></div>

          <%= f.label :current_password, "Contraseña actual", class: "floating-label" do %>
            <%= f.password_field :current_password, autocomplete: "current-password", class: "input w-full", placeholder: "Contraseña actual" %>
            <span>Contraseña actual</span>
          <% end %>
          <p class="text-xs text-base-content/50 -mt-2">Necesitamos tu contraseña actual para confirmar los cambios</p>

          <%= f.submit "Guardar cambios", class: "btn btn-primary w-full" %>
        <% end %>
      </div>
    </div>

    <div class="flex flex-col gap-8">
      <div class="card bg-base-100 shadow-xl">
        <div class="card-body">
          <h2 class="card-title text-error">Eliminar Cuenta</h2>
          <p class="text-sm text-base-content/60">Esta acción es irreversible. Se eliminarán todos tus datos.</p>
          <div class="card-actions justify-end mt-2">
            <%= button_to "Eliminar mi cuenta", registration_path(resource_name), method: :delete, class: "btn btn-error btn-outline btn-sm", data: { turbo_confirm: "¿Estás seguro? Esta acción no se puede deshacer." } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
