<!DOCTYPE html>
<html data-theme="light">
  <head>
    <title><%= content_for(:title) || "Yuntapp Panel" %></title>
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>
    <%= render "shared/google_fonts" %>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <%= render "shared/skip_to_main" %>
    <%= render "shared/flash" %>
    <div class="drawer lg:drawer-open">
      <input id="my-drawer-2" type="checkbox" class="drawer-toggle">
      <div class="drawer-content flex flex-col items-center justify-start min-h-screen">
        <!-- Page content here -->
        <div class="w-full navbar bg-base-100 lg:hidden shadow-sm">
            <div class="flex-none">
                <label for="my-drawer-2" class="btn btn-square btn-ghost drawer-button lg:hidden" aria-label="Abrir menú">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-6 h-6 stroke-current" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                </label>
            </div>
            <div class="flex-1 px-2 mx-2 font-semibold text-lg truncate"><%= content_for(:title) %></div>
        </div>

        <%= render "shared/breadcrumbs", home_label: "Mi Panel", home_path: panel_root_path %>

        <main id="main-content" tabindex="-1" class="container mx-auto mt-4 mb-5 px-5 flex flex-col w-full">
            <%= yield %>
        </main>
        <%= render "shared/footer" %>
      </div>
      <div class="drawer-side h-screen">
        <label for="my-drawer-2" aria-label="close sidebar" class="drawer-overlay"></label>
        <ul class="menu p-4 w-80 bg-base-200 text-base-content h-full flex flex-col overflow-y-auto">
          <li class="mb-4 px-2"><%= render "shared/logo", variant: :horizontal, size: "md" %></li>
          <li><%= link_to "Dashboard", panel_root_path, class: ("active" if current_page?(panel_root_path)) %></li>
          <%# Un socio aprobado no tiene solicitud "actual" y onboarding#step1
              lo redirige de vuelta al dashboard — el link sería un duplicado. %>
          <% unless current_user.member&.approved? %>
            <% onboarding_req = current_user.current_onboarding_request %>
            <% onboarding_link = (onboarding_req.present? && !onboarding_req.draft?) ? panel_onboarding_status_path : panel_onboarding_step1_path %>
            <li>
              <%= link_to onboarding_link, class: ("active" if controller_name == "onboarding") do %>
                <%= I18n.t('panel.onboarding.status.sidebar') %>
                <% if onboarding_req.present? && !onboarding_req.draft? %>
                  <%= status_badge(onboarding_req.status) %>
                <% end %>
              <% end %>
            </li>
          <% end %>

          <li class="menu-title mt-4">Mis Cosas</li>
          <li><%= link_to "Mi Perfil", panel_profile_path, class: ("active" if controller_name == "profile") %></li>
          <% if current_user.member %>
            <li><%= link_to "Mi Junta", panel_neighborhood_association_path, class: ("active" if controller_name == "neighborhood_association") %></li>
          <% end %>

          <% if current_user.household_admin? %>
            <li><%= link_to "Certificados", panel_residence_certificates_path, class: ("active" if controller_name == "residence_certificates") %></li>
            <li><%= link_to "Residentes Dependientes", panel_dependents_path, class: ("active" if controller_name == "dependents") %></li>
          <% end %>

          <li class="mt-auto pt-4 border-t border-base-300">
            <div class="text-xs text-base-content/60 truncate px-2"><%= current_user.email %></div>
          </li>
          <li class="menu-title">Sistema</li>
          <li><%= link_to "Mi Cuenta", edit_user_registration_path, class: ("active" if controller_name == "registrations") %></li>
          <li><%= link_to "Reiniciar Onboarding", panel_onboarding_restart_path, data: { turbo_method: :delete, turbo_confirm: "¿Estás seguro? Esto eliminará tu progreso actual y podrás registrarte en otra junta." }, class: "text-warning" %></li>
          <li><%= link_to I18n.t('actions.reset'), panel_reset_account_path, data: { turbo_method: :delete, turbo_confirm: I18n.t('panel.account_resets.confirm') }, class: "text-error" %></li>
          <li><%= link_to "Cerrar Sesión", destroy_user_session_path, data: { turbo_method: :delete } %></li>
        </ul>

      </div>
    </div>
    <%= yield :filter_drawer %>
  </body>
</html>
