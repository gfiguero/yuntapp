<% content_for :title do %>
  <%= I18n.t('superadmin.users.index.title') %>
<% end %>

<% content_for :breadcrumb do %>
  <li><%= link_to I18n.t('superadmin.users.index.title'), superadmin_users_path %></li>
  <li><%= I18n.t('superadmin.users.show.identifier', id: @user.id) %></li>
<% end %>

<div class="w-full">
  <h1 class="font-bold text-4xl my-4"><%= I18n.t('superadmin.users.index.title') %></h1>
  <h3 class="font-bold text-xl mb-4"><%= I18n.t('superadmin.users.show.identifier', id: @user.id) %></h3>
  <%= render "buttons" %>
  <%= render @user %>
</div>
