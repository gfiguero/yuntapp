<% content_for :title do %>
  <%= I18n.t('admin.certificate_pricings.new.title') %>
<% end %>

<% content_for :breadcrumb do %>
  <li><%= link_to I18n.t('admin.certificate_pricings.index.title'), admin_certificate_pricings_path %></li>
  <li><%= I18n.t('actions.new') %></li>
<% end %>

<div class="w-full">
  <h1 class="font-bold text-4xl my-4"><%= I18n.t('admin.certificate_pricings.new.title') %></h1>
  <p class="mb-4 text-base-content/70"><%= I18n.t('admin.certificate_pricings.new.description') %></p>

  <div class="flex flex-row gap-2 mb-4">
    <%= link_to raw(icon('list') + I18n.t('actions.index')), admin_certificate_pricings_path, class: "btn btn-soft" %>
  </div>

  <%= form_with(model: [:admin, @certificate_pricing], class: "grid gap-4 w-full md:w-1/3") do |form| %>
    <% invalid = @certificate_pricing.errors.include?(:price) %>
    <%= form.label :price, I18n.t('activerecord.attributes.certificate_pricing.price'), class: "floating-label" do %>
      <%= form.number_field :price, min: CertificatePricing::MINIMUM_PRICE, class: "input w-full validator #{'input-error' if invalid}", required: true, placeholder: I18n.t('activerecord.attributes.certificate_pricing.price') %>
      <span><%= I18n.t('admin.certificate_pricings.new.price_help', min: CertificatePricing::MINIMUM_PRICE) %></span>
    <% end %>
    <%= raw(error_message(invalid, @certificate_pricing.errors.full_messages_for(:price))) if invalid %>

    <%= form.submit I18n.t('actions.save'), class: "btn btn-success" %>
  <% end %>
</div>
