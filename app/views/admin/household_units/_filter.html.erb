<% content_for :filter_drawer do %>
  <div class="drawer z-50">
    <%= checkbox_tag :filter, true, class: "drawer-toggle" %>
    <div class="drawer-side">
      <%= label_tag :filter, "", class: "drawer-overlay", aria: { label: "close sidebar" } %>

      <div class="menu bg-base-200 min-h-full w-80 p-4">
        <h3 class="font-bold text-xl"><%= I18n.t('actions.filter') %></h3>
        <div class="divider"></div>

        <%= form_tag admin_household_units_path, method: :get do %>

          <div class="grid gap-4">
            <div>
              <%= label_tag :neighborhood_delegation_id, I18n.t('activerecord.attributes.household_unit.neighborhood_delegation'), class: "label" %>
              <%= select_tag :neighborhood_delegation_id,
                    options_from_collection_for_select(current_neighborhood_association.neighborhood_delegations.order(:name), :id, :name, params[:neighborhood_delegation_id]),
                    include_blank: I18n.t('helpers.select.prompt'),
                    class: "select select-bordered w-full" %>
            </div>

            <div>
              <%= label_tag :number, I18n.t('activerecord.attributes.household_unit.number'), class: "label" %>
              <%= text_field_tag :number, params[:number], class: "input", autocomplete: "off" %>
            </div>

            <%= button_tag raw(icon('filter') + I18n.t('actions.filter')), type: 'submit', class: "btn btn-info" %>
            <%= link_to raw(icon('restart') + I18n.t('actions.restart')), admin_household_units_path, class: "btn" %>
          </div>

        <% end %>
      </div>
    </div>
  </div>
<% end %>
