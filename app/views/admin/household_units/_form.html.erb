<%= form_with(model: [:admin, household_unit], class: "grid gap-4 w-1/3") do |form| %>

  <% invalid = household_unit.errors.include?(:neighborhood_delegation_id) %>
  <%= form.label :neighborhood_delegation_id, I18n.t('activerecord.attributes.household_unit.neighborhood_delegation'), class: "floating-label" do %>
    <%= form.collection_select :neighborhood_delegation_id, NeighborhoodDelegation.all, :id, :name, { prompt: true }, { class: "select w-full validator #{'input-error' if invalid}", required: true } %>
    <span><%= I18n.t('activerecord.attributes.household_unit.neighborhood_delegation') %></span>
  <% end %>
  <%= raw(error_message(invalid, household_unit.errors.full_messages_for(:neighborhood_delegation_id))) %>

  <% invalid = household_unit.errors.include?(:number) %>
  <%= form.label :number, I18n.t('activerecord.attributes.household_unit.number'), class: "floating-label" do %>
    <%= form.text_field :number, class: "input w-full validator #{'input-error' if invalid}", required: true, placeholder: I18n.t('activerecord.attributes.household_unit.number') %>
    <span><%= I18n.t('activerecord.attributes.household_unit.number') %></span>
  <% end %>
  <%= raw(error_message(invalid, household_unit.errors.full_messages_for(:number))) %>

  <% invalid = household_unit.errors.include?(:street_name) %>
  <%= form.label :street_name, I18n.t('activerecord.attributes.household_unit.street_name'), class: "floating-label" do %>
    <%= form.text_field :street_name, class: "input w-full validator #{'input-error' if invalid}", placeholder: I18n.t('activerecord.attributes.household_unit.street_name') %>
    <span><%= I18n.t('activerecord.attributes.household_unit.street_name') %></span>
  <% end %>
  <%= raw(error_message(invalid, household_unit.errors.full_messages_for(:street_name))) %>

  <% invalid = household_unit.errors.include?(:address_detail) %>
  <%= form.label :address_detail, I18n.t('activerecord.attributes.household_unit.address_detail'), class: "floating-label" do %>
    <%= form.text_field :address_detail, class: "input w-full validator #{'input-error' if invalid}", placeholder: I18n.t('activerecord.attributes.household_unit.address_detail') %>
    <span><%= I18n.t('activerecord.attributes.household_unit.address_detail') %></span>
  <% end %>
  <%= raw(error_message(invalid, household_unit.errors.full_messages_for(:address_detail))) %>

  <% invalid = household_unit.errors.include?(:city) %>
  <%= form.label :city, I18n.t('activerecord.attributes.household_unit.city'), class: "floating-label" do %>
    <%= form.text_field :city, class: "input w-full validator #{'input-error' if invalid}", placeholder: I18n.t('activerecord.attributes.household_unit.city') %>
    <span><%= I18n.t('activerecord.attributes.household_unit.city') %></span>
  <% end %>
  <%= raw(error_message(invalid, household_unit.errors.full_messages_for(:city))) %>

  <% invalid = household_unit.errors.include?(:region) %>
  <%= form.label :region, I18n.t('activerecord.attributes.household_unit.region'), class: "floating-label" do %>
    <%= form.text_field :region, class: "input w-full validator #{'input-error' if invalid}", placeholder: I18n.t('activerecord.attributes.household_unit.region') %>
    <span><%= I18n.t('activerecord.attributes.household_unit.region') %></span>
  <% end %>
  <%= raw(error_message(invalid, household_unit.errors.full_messages_for(:region))) %>

  <% invalid = household_unit.errors.include?(:country) %>
  <%= form.label :country, I18n.t('activerecord.attributes.household_unit.country'), class: "floating-label" do %>
    <%= form.text_field :country, class: "input w-full validator #{'input-error' if invalid}", placeholder: I18n.t('activerecord.attributes.household_unit.country') %>
    <span><%= I18n.t('activerecord.attributes.household_unit.country') %></span>
  <% end %>
  <%= raw(error_message(invalid, household_unit.errors.full_messages_for(:country))) %>

  <% invalid = household_unit.errors.include?(:postal_code) %>
  <%= form.label :postal_code, I18n.t('activerecord.attributes.household_unit.postal_code'), class: "floating-label" do %>
    <%= form.text_field :postal_code, class: "input w-full validator #{'input-error' if invalid}", placeholder: I18n.t('activerecord.attributes.household_unit.postal_code') %>
    <span><%= I18n.t('activerecord.attributes.household_unit.postal_code') %></span>
  <% end %>
  <%= raw(error_message(invalid, household_unit.errors.full_messages_for(:postal_code))) %>

  <%= form.submit I18n.t('actions.save'), class: "btn btn-success" %>
<% end %>
