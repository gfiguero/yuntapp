<tr class="hover:bg-base-300">
  <td><%= household_unit.neighborhood_delegation.name %></td>
  <td><%= household_unit.number %></td>
  <td>
    <%= icon_link_to 'show', [:admin, household_unit], I18n.t('actions.show'), class: "btn btn-sm btn-soft btn-info" %>
    <%= icon_link_to 'edit', edit_admin_household_unit_path(household_unit), I18n.t('actions.edit'), class: "btn btn-sm btn-soft btn-success" %>
    <%= icon_link_to 'delete', delete_admin_household_unit_path(household_unit), I18n.t('actions.delete'), class: "btn btn-sm btn-soft btn-warning" %>
  </td>
</tr>
