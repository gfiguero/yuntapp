<tr class="hover:bg-base-300">
  <td><%= neighborhood_delegation.name %></td>
  <td><%= neighborhood_delegation.neighborhood_association.name %></td>
  <td>
    <div class="tooltip" data-tip="<%= I18n.t('actions.show') %>">
      <%= link_to icon('show'), [:admin, neighborhood_delegation], class: "btn btn-sm btn-soft btn-info" %>
    </div>
    <%= icon_link_to 'edit', edit_admin_neighborhood_delegation_path(neighborhood_delegation), I18n.t('actions.edit'), class: "btn btn-sm btn-soft btn-success" %>
    <%= icon_link_to 'delete', delete_admin_neighborhood_delegation_path(neighborhood_delegation), I18n.t('actions.delete'), class: "btn btn-sm btn-soft btn-warning" %>
  </td>
</tr>
