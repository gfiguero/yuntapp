<tr class="hover:bg-base-300">
  <td><%= user.email %></td>
  <td><%= user.first_name %></td>
  <td><%= user.last_name %></td>
  <td>
    <% if user.admin? %>
      <span class="badge badge-success text-white">Admin</span>
    <% else %>
      <span class="badge badge-ghost">User</span>
    <% end %>
  </td>
  <td>
    <%= icon_link_to 'show', [:admin, user], I18n.t('actions.show'), class: "btn btn-sm btn-soft btn-info" %>
    <%= icon_link_to 'edit', edit_admin_user_path(user), I18n.t('actions.edit'), class: "btn btn-sm btn-soft btn-success" %>
    <%= icon_link_to 'delete', delete_admin_user_path(user), I18n.t('actions.delete'), class: "btn btn-sm btn-soft btn-warning" %>
  </td>
</tr>
