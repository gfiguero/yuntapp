<% content_for :title do %>
  <%= I18n.t('admin.onboarding_requests.index.title') %>
<% end %>

<% content_for :breadcrumb do %>
  <li><%= link_to I18n.t('admin.onboarding_requests.index.title'), admin_onboarding_requests_path %></li>
  <li><%= @onboarding_request.id %></li>
<% end %>

<div class="w-full">
  <h1 class="font-bold text-4xl my-4"><%= I18n.t('admin.onboarding_requests.index.title') %></h1>
  <h3 class="font-bold text-xl mb-4"><%= I18n.t('admin.onboarding_requests.show.identifier', id: @onboarding_request.id) %></h3>
  <%= render "buttons" %>

  <% if @onboarding_request.pending? %>
    <div class="alert alert-info mb-4">
      <span><%= I18n.t('admin.onboarding_reviews.show.pending_review_message') %></span>
      <% review_path = if @onboarding_request.identity_verification_request&.approved? && @onboarding_request.residence_verification_request&.approved?
          review_step3_admin_onboarding_request_path(@onboarding_request)
        elsif @onboarding_request.identity_verification_request&.approved?
          review_step2_admin_onboarding_request_path(@onboarding_request)
        else
          review_step1_admin_onboarding_request_path(@onboarding_request)
        end %>
      <%= link_to I18n.t('admin.onboarding_reviews.show.start_review'), review_path, class: "btn btn-primary btn-sm" %>
    </div>
  <% end %>

  <div class="grid grid-cols-1 gap-4">
    <%= render "shared/onboarding/onboarding_data_card", onboarding_request: @onboarding_request %>
    <%= render "shared/onboarding/association_card", onboarding_request: @onboarding_request %>

    <% if @onboarding_request.identity_verification_request %>
      <%= render "shared/onboarding/identity_card", identity_request: @onboarding_request.identity_verification_request %>
    <% end %>

    <% if @onboarding_request.residence_verification_request %>
      <%= render "shared/onboarding/residence_card", residence_request: @onboarding_request.residence_verification_request %>
    <% end %>
  </div>
</div>
