<% content_for :title do %>
  <%= I18n.t('admin.listing_pricings.index.title') %>
<% end %>

<% content_for :breadcrumb do %>
  <li><%= I18n.t('admin.listing_pricings.index.title') %></li>
<% end %>

<div class="w-full">
  <h1 class="font-bold text-4xl my-4"><%= I18n.t('admin.listing_pricings.index.title') %></h1>
  <p class="mb-4 text-base-content/70"><%= I18n.t('admin.listing_pricings.index.description') %></p>

  <% if @current_pricing.present? %>
    <div class="card bg-base-100 border border-base-content/5 mb-6 max-w-md">
      <div class="card-body">
        <h2 class="card-title"><%= I18n.t('admin.listing_pricings.index.current_pricing') %></h2>
        <p class="text-3xl font-bold">$<%= number_with_delimiter(@current_pricing.price) %> CLP</p>
        <p class="text-xs text-base-content/60"><%= I18n.t('admin.listing_pricings.index.effective_since', date: l(@current_pricing.effective_from)) %></p>
      </div>
    </div>
  <% else %>
    <div class="alert alert-warning mb-6">
      <%= I18n.t('admin.listing_pricings.index.no_current_pricing') %>
    </div>
  <% end %>

  <div class="flex flex-row gap-2 mb-4">
    <%= link_to raw(icon('new') + I18n.t('admin.listing_pricings.index.new_pricing')), new_admin_listing_pricing_path, class: "btn btn-soft btn-primary" %>
  </div>

  <h2 class="font-bold text-2xl my-4"><%= I18n.t('admin.listing_pricings.index.history') %></h2>
  <% if @listing_pricings.any? %>
    <div class="overflow-x-auto rounded-box border border-base-content/5 bg-base-100">
      <table class="table">
        <thead>
          <tr>
            <th><%= I18n.t('activerecord.attributes.listing_pricing.price') %></th>
            <th><%= I18n.t('activerecord.attributes.listing_pricing.effective_from') %></th>
            <th><%= I18n.t('activerecord.attributes.listing_pricing.effective_to') %></th>
            <th><%= I18n.t('activerecord.attributes.listing_pricing.created_by') %></th>
          </tr>
        </thead>
        <tbody>
        <% @listing_pricings.each do |pricing| %>
          <tr class="hover:bg-base-300">
            <td>$<%= number_with_delimiter(pricing.price) %></td>
            <td><%= l(pricing.effective_from) %></td>
            <td>
              <% if pricing.effective_to.present? %>
                <%= l(pricing.effective_to) %>
              <% else %>
                <span class="badge badge-success"><%= I18n.t('admin.listing_pricings.index.active') %></span>
              <% end %>
            </td>
            <td><%= pricing.created_by&.name %></td>
          </tr>
        <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-base-content/70"><%= I18n.t('admin.listing_pricings.index.empty') %></p>
  <% end %>
</div>
