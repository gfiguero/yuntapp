<tr class="hover:bg-base-300">
  <td><%= member.name %></td>
  <td><%= member.run %></td>
  <td>
    <% if member.pending? %>
      <span class="badge badge-warning badge-sm"><%= I18n.t('activerecord.attributes.member/status.pending') %></span>
    <% elsif member.approved? %>
      <span class="badge badge-success badge-sm"><%= I18n.t('activerecord.attributes.member/status.approved') %></span>
    <% elsif member.rejected? %>
      <span class="badge badge-error badge-sm"><%= I18n.t('activerecord.attributes.member/status.rejected') %></span>
    <% end %>
  </td>
  <td>
    <%= icon_link_to 'show', [:admin, member], I18n.t('actions.show'), class: "btn btn-sm btn-soft btn-info" %>
    <%= icon_link_to 'edit', edit_admin_member_path(member), I18n.t('actions.edit'), class: "btn btn-sm btn-soft btn-success" %>
    <%= icon_link_to 'delete', delete_admin_member_path(member), I18n.t('actions.delete'), class: "btn btn-sm btn-soft btn-warning" %>
  </td>
</tr>
