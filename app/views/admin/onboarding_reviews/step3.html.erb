<% content_for :title do %>
  <%= I18n.t('admin.onboarding_reviews.title') %>
<% end %>

<% content_for :breadcrumb do %>
  <li><%= link_to I18n.t('admin.onboarding_requests.index.title'), admin_onboarding_requests_path %></li>
  <li><%= link_to I18n.t('admin.onboarding_requests.show.identifier', id: @onboarding_request.id), admin_onboarding_request_path(@onboarding_request) %></li>
  <li><%= I18n.t('admin.onboarding_reviews.steps.approval') %></li>
<% end %>

<div class="w-full">
  <h1 class="font-bold text-4xl my-4"><%= I18n.t('admin.onboarding_reviews.title') %></h1>
  <h3 class="font-bold text-xl mb-2"><%= I18n.t('admin.onboarding_requests.show.identifier', id: @onboarding_request.id) %></h3>

  <%= render "review_steps", current_step: 3 %>

  <h2 class="font-bold text-2xl mb-2"><%= I18n.t('admin.onboarding_reviews.step3.title') %></h2>
  <p class="text-base-content/60 mb-6"><%= I18n.t('admin.onboarding_reviews.step3.description') %></p>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <%# Identity Summary %>
    <div class="card bg-base-200 shadow-sm">
      <div class="card-body">
        <div class="flex justify-between items-center">
          <h3 class="card-title"><%= I18n.t('admin.onboarding_reviews.steps.identity') %></h3>
          <%= status_badge(@identity_request.status) %>
        </div>
        <dl class="mt-2 space-y-1">
          <div>
            <dt class="text-xs text-base-content/50"><%= I18n.t('activerecord.attributes.verified_identity.name') %></dt>
            <dd class="font-medium"><%= @identity_request.full_name %></dd>
          </div>
          <div>
            <dt class="text-xs text-base-content/50"><%= I18n.t('activerecord.attributes.verified_identity.run') %></dt>
            <dd class="font-mono"><%= @identity_request.run %></dd>
          </div>
          <% if @identity_request.phone.present? %>
            <div>
              <dt class="text-xs text-base-content/50"><%= I18n.t('activerecord.attributes.verified_identity.phone') %></dt>
              <dd><%= @identity_request.phone %></dd>
            </div>
          <% end %>
        </dl>
      </div>
    </div>

    <%# Residence Summary %>
    <div class="card bg-base-200 shadow-sm">
      <div class="card-body">
        <div class="flex justify-between items-center">
          <h3 class="card-title"><%= I18n.t('admin.onboarding_reviews.steps.residence') %></h3>
          <%= status_badge(@residence_request.status) %>
        </div>
        <dl class="mt-2 space-y-1">
          <% if @residence_request.neighborhood_delegation.present? %>
            <div>
              <dt class="text-xs text-base-content/50"><%= I18n.t('activerecord.attributes.household_unit.neighborhood_delegation') %></dt>
              <dd class="font-medium"><%= @residence_request.neighborhood_delegation.name %></dd>
            </div>
          <% end %>
          <% if @residence_request.street_name.present? %>
            <div>
              <dt class="text-xs text-base-content/50"><%= I18n.t('activerecord.attributes.household_unit.street_name') %></dt>
              <dd class="font-medium"><%= @residence_request.street_name %></dd>
            </div>
          <% end %>
          <div>
            <dt class="text-xs text-base-content/50"><%= I18n.t('activerecord.attributes.household_unit.number') %></dt>
            <dd><%= @residence_request.number %></dd>
          </div>
          <% if @residence_request.address_detail.present? %>
            <div>
              <dt class="text-xs text-base-content/50"><%= I18n.t('activerecord.attributes.household_unit.address_detail') %></dt>
              <dd><%= @residence_request.address_detail %></dd>
            </div>
          <% end %>
        </dl>
      </div>
    </div>
  </div>

  <%# Transition preview — always shown %>
  <% if @existing_identity.present? %>
    <% identity_fields = [
      [I18n.t('activerecord.attributes.verified_identity.first_name'), @existing_identity.first_name, @identity_request.first_name],
      [I18n.t('activerecord.attributes.verified_identity.last_name'), @existing_identity.last_name, @identity_request.last_name],
      [I18n.t('activerecord.attributes.verified_identity.phone'), @existing_identity.phone, @identity_request.phone],
    ].reject { |_, cur, new_val| cur.blank? && new_val.blank? } %>
    <% current_residency = @existing_identity.residencies.select(&:approved?).max_by(&:created_at) %>
  <% else %>
    <% identity_fields = [
      [I18n.t('activerecord.attributes.verified_identity.first_name'), nil, @identity_request.first_name],
      [I18n.t('activerecord.attributes.verified_identity.last_name'), nil, @identity_request.last_name],
      [I18n.t('activerecord.attributes.verified_identity.phone'), nil, @identity_request.phone],
    ].reject { |_, cur, new_val| cur.blank? && new_val.blank? } %>
    <% current_residency = nil %>
  <% end %>

  <div class="mt-6">
    <% if @existing_identity.present? %>
      <div class="alert alert-warning mb-4">
        <span><%= I18n.t('admin.onboarding_reviews.step3.existing_identity_found') %></span>
      </div>
    <% else %>
      <div class="alert alert-info mb-4">
        <span><%= I18n.t('admin.onboarding_reviews.step3.new_identity_info') %></span>
      </div>
    <% end %>

    <%# Identity transition %>
    <div class="card bg-base-200 shadow-sm">
      <div class="card-body">
        <h3 class="card-title"><%= I18n.t('admin.onboarding_reviews.step3.identity_transition') %></h3>

        <div class="flex flex-col md:flex-row items-stretch gap-4 mt-2">
          <%# Current identity %>
          <div class="flex-1 rounded-lg border-2 border-base-300 bg-base-100 p-4">
            <div class="flex items-center gap-2 mb-3">
              <%= raw(icon('id', class: 'text-base-content/40')) %>
              <span class="font-semibold text-sm"><%= I18n.t('admin.onboarding_reviews.step3.current_data') %></span>
            </div>
            <% if @existing_identity.present? %>
              <dl class="space-y-2">
                <% identity_fields.each do |label, current_value, _| %>
                  <div>
                    <dt class="text-xs text-base-content/50"><%= label %></dt>
                    <dd class="font-medium text-sm"><%= current_value.presence || "—" %></dd>
                  </div>
                <% end %>
              </dl>
            <% else %>
              <p class="text-sm text-base-content/40 italic"><%= I18n.t('admin.onboarding_reviews.step3.no_current_identity') %></p>
            <% end %>
          </div>

          <%# Arrow %>
          <div class="flex items-center justify-center">
            <div class="hidden md:block text-base-content/30">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
              </svg>
            </div>
            <div class="md:hidden text-base-content/30">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3" />
              </svg>
            </div>
          </div>

          <%# Resulting identity %>
          <div class="flex-1 rounded-lg border-2 border-primary/30 bg-primary/5 p-4">
            <div class="flex items-center gap-2 mb-3">
              <%= raw(icon('id', class: 'text-primary')) %>
              <span class="font-semibold text-sm"><%= I18n.t('admin.onboarding_reviews.step3.resulting_data') %></span>
            </div>
            <dl class="space-y-2">
              <% identity_fields.each do |label, current_value, new_value| %>
                <div>
                  <dt class="text-xs text-base-content/50"><%= label %></dt>
                  <dd class="font-medium text-sm">
                    <%= new_value.presence || "—" %>
                    <% if @existing_identity.present? %>
                      <% if current_value == new_value %>
                        <span class="badge badge-success badge-sm ml-1"><%= I18n.t('admin.onboarding_reviews.step3.match') %></span>
                      <% else %>
                        <span class="badge badge-warning badge-sm ml-1"><%= I18n.t('admin.onboarding_reviews.step3.will_update') %></span>
                      <% end %>
                    <% else %>
                      <span class="badge badge-info badge-sm ml-1"><%= I18n.t('admin.onboarding_reviews.step3.will_create') %></span>
                    <% end %>
                  </dd>
                </div>
              <% end %>
            </dl>
          </div>
        </div>
      </div>
    </div>

    <%# Residence transition %>
    <div class="card bg-base-200 shadow-sm mt-4">
      <div class="card-body">
        <h3 class="card-title"><%= I18n.t('admin.onboarding_reviews.step3.residence_transition') %></h3>

        <div class="flex flex-col md:flex-row items-stretch gap-4 mt-2">
          <%# Current residence %>
          <div class="flex-1 rounded-lg border-2 border-base-300 bg-base-100 p-4">
            <div class="flex items-center gap-2 mb-2">
              <%= raw(icon('map-pin', class: 'text-base-content/40')) %>
              <span class="font-semibold text-sm"><%= I18n.t('admin.onboarding_reviews.step3.current_residence') %></span>
            </div>
            <% if current_residency.present? %>
              <p class="font-medium text-sm"><%= current_residency.household_unit.neighborhood_delegation.neighborhood_association.name %></p>
              <p class="text-sm text-base-content/60">
                <%= current_residency.household_unit.neighborhood_delegation.name %>
                — #<%= current_residency.household_unit.number %>
              </p>
              <% if current_residency.household_unit.street_name.present? %>
                <p class="text-sm text-base-content/60"><%= current_residency.household_unit.street_name %></p>
              <% end %>
              <% if current_residency.household_admin? %>
                <span class="badge badge-info badge-sm mt-2"><%= I18n.t('admin.onboarding_reviews.step3.household_admin') %></span>
              <% end %>
            <% else %>
              <p class="text-sm text-base-content/40 italic"><%= I18n.t('admin.onboarding_reviews.step3.no_current_residence') %></p>
            <% end %>
          </div>

          <%# Arrow %>
          <div class="flex items-center justify-center">
            <div class="hidden md:block text-base-content/30">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
              </svg>
            </div>
            <div class="md:hidden text-base-content/30">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3" />
              </svg>
            </div>
          </div>

          <%# New residence %>
          <div class="flex-1 rounded-lg border-2 border-primary/30 bg-primary/5 p-4">
            <div class="flex items-center gap-2 mb-2">
              <%= raw(icon('map-pin', class: 'text-primary')) %>
              <span class="font-semibold text-sm"><%= I18n.t('admin.onboarding_reviews.step3.new_residence') %></span>
            </div>
            <p class="font-medium text-sm"><%= @onboarding_request.neighborhood_association.name %></p>
            <% if @residence_request.neighborhood_delegation.present? %>
              <p class="text-sm text-base-content/60">
                <%= @residence_request.neighborhood_delegation.name %>
                — #<%= @residence_request.number %>
              </p>
            <% end %>
            <% if @residence_request.street_name.present? %>
              <p class="text-sm text-base-content/60"><%= @residence_request.street_name %></p>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# Approve form wraps both matching section and buttons %>
  <%= form_with url: review_step3_admin_onboarding_request_path(@onboarding_request), method: :patch, class: "mt-6" do %>

    <% if @matching_household_units.any? %>
      <%# Matching household units found %>
      <div class="alert alert-info mb-4">
        <span><%= I18n.t('admin.onboarding_reviews.step3.matching_units_found') %></span>
      </div>

      <div class="space-y-3 mb-6">
        <% @matching_household_units.each do |hu| %>
          <% hu_association = hu.neighborhood_delegation.neighborhood_association %>
          <% same_association = hu_association == current_neighborhood_association %>
          <label class="card bg-base-200 shadow-sm cursor-pointer has-[:checked]:ring-2 has-[:checked]:ring-primary">
            <div class="card-body flex-row items-center gap-4 py-4">
              <input type="radio" name="household_unit_id" value="<%= hu.id %>"
                     class="radio radio-primary">
              <div>
                <p class="font-medium">
                  <%= hu.neighborhood_delegation.name %> — #<%= hu.number %>
                </p>
                <% if hu.street_name.present? %>
                  <p class="text-sm text-base-content/60"><%= hu.street_name %></p>
                <% end %>
                <% unless same_association %>
                  <p class="text-sm text-base-content/60">
                    <%= I18n.t('admin.onboarding_reviews.step3.association') %>: <%= hu_association.name %>
                  </p>
                <% end %>
                <p class="text-sm text-base-content/60">
                  <%= I18n.t('admin.onboarding_reviews.step3.current_members') %>:
                  <%= hu.approved_residencies.map(&:name).join(', ').presence || I18n.t('admin.onboarding_reviews.step3.no_members') %>
                </p>
              </div>
            </div>
          </label>
        <% end %>

        <%# Option to create new %>
        <label class="card bg-base-200 shadow-sm cursor-pointer has-[:checked]:ring-2 has-[:checked]:ring-primary">
          <div class="card-body flex-row items-center gap-4 py-4">
            <input type="radio" name="household_unit_id" value="new"
                   class="radio radio-primary" checked>
            <div>
              <p class="font-medium"><%= I18n.t('admin.onboarding_reviews.step3.create_new_unit') %></p>
              <p class="text-sm text-base-content/60"><%= I18n.t('admin.onboarding_reviews.step3.create_new_unit_description') %></p>
            </div>
          </div>
        </label>
      </div>
    <% else %>
      <div class="alert alert-warning mb-4">
        <span><%= I18n.t('admin.onboarding_reviews.step3.approve_warning') %></span>
      </div>
    <% end %>

    <div class="flex gap-2 mb-4">
      <%= link_to I18n.t('actions.back'), review_step2_admin_onboarding_request_path(@onboarding_request), class: "btn btn-soft" %>
      <button type="submit" class="btn btn-success">
        <%= I18n.t('admin.onboarding_reviews.step3.approve_button') %>
      </button>
    </div>
  <% end %>

  <%# Reject %>
  <div class="collapse collapse-arrow bg-base-200">
    <input type="checkbox">
    <div class="collapse-title font-medium text-error"><%= I18n.t('admin.onboarding_reviews.step3.reject_title') %></div>
    <div class="collapse-content">
      <%= form_with url: review_reject_admin_onboarding_request_path(@onboarding_request), method: :patch, class: "space-y-3" do %>
        <textarea name="rejection_reason" class="textarea textarea-bordered w-full"
                  placeholder="<%= I18n.t('admin.onboarding_reviews.step3.rejection_reason_placeholder') %>"
                  rows="3"></textarea>
        <button type="submit" class="btn btn-error">
          <%= I18n.t('admin.onboarding_reviews.step3.reject_button') %>
        </button>
      <% end %>
    </div>
  </div>
</div>
