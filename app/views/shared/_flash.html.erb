<div class="toast toast-end toast-top z-50">
  <% flash.each do |key, message| %>
    <%
      key_str = key.to_s
      alert_class = case key_str
      when "notice", "success" then "alert-success"
      when "alert", "error", "danger" then "alert-error"
      when "warning" then "alert-warning"
      when "info" then "alert-info"
      else "alert-info"
      end
      # WCAG: errores/warnings → assertive (interrumpen); resto polite.
      severe = %w[alert error danger warning].include?(key_str)
      aria_live = severe ? "assertive" : "polite"
      role = severe ? "alert" : "status"
    %>
    <div class="alert <%= alert_class %> shadow-lg"
         data-controller="flash"
         data-flash-delay-value="5000"
         role="<%= role %>"
         aria-live="<%= aria_live %>">

      <% case key_str %>
      <% when "notice", "success" %>
        <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      <% when "alert", "error", "danger" %>
        <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      <% when "warning" %>
        <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
      <% else %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
      <% end %>

      <span><%= message %></span>

      <button type="button"
              class="btn btn-sm btn-ghost btn-circle"
              data-action="click->flash#dismiss"
              aria-label="<%= I18n.t('shared.flash.dismiss') %>">
        <%= icon('close', class: 'w-4 h-4') %>
      </button>
    </div>
  <% end %>
</div>
